{
  "manifest_version": 3,
  "name": "엔트리 블록 청소",
  "version": "1.6",
  "description": "엔트리 워크스페이스 전용 블록 청소기입니다.",
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://playentry.org/ws*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["btn_icon.png"],
      "matches": ["*://playentry.org/*"]
    }
  ]
}

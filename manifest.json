{
  "manifest_version": 3,
  "name": "엔트리 블록 청소",
  "version": "1.0",
  "description": "엔트리 만들기 화면에서 연결되지 않은 흩어진 블록을 삭제합니다.",
  
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://playentry.org/*"
  ]
}
